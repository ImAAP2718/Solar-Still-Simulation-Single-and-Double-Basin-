def Heat_transfer_rate_radiation(Ta, Tb,effems): 
    ems1 = 0.8 
    ems2 = 0.9 
    T1 = Ta + 273.15 
    T2 = Tb + 273.15 
    eps_eff = 1 / ((1/ems1) + (1/ems2) - 1) 
    sigma = 5.669e-8 
    return effems * sigma * (T1**4 - T2**4) 
 
def calculate_vapor_pressure(T_C): 
    # Corrected Antoine equation for water (0-100°C) 
    A = 8.07131 
    B = 1730.63 
    C = 233.426 
    hgapp= 10**(A - B/(T_C + C))  # mmHg 
    return 113.3*hgapp 
 
def calculate_vapor_pressulre(T_C): 
    A = 25.317 
    B = 5144 
    C = 273.15 
    return exp(A - (B/(T_C + C)))  
 
def Heat_Transfer_Rate_Convection(T1, T2): 
    Tw = T1 + 273.15 
    Tg = T2 + 273.15 
    Pw = calculate_vapor_pressure(T1) 
    Pg = calculate_vapor_pressure(T2) 
     
    term = (Tw - Tg) + ((Pw - Pg) * Tw / (268900 - Pw)) 
    x = np.cbrt(term)  
    hconv = 0.884 * x 
    return hconv * (Tw - Tg) 
 
def Heat_Transfer_Rate_Conduction(k, T1, T2, area, thickness): 
    return (k * area * (T1 - T2)) / thickness 
 
